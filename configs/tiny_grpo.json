{
  "run_name": "tiny_grpo",
  "model": {
    "vocab_size": 260,
    "max_seq_len": 192,
    "hidden_size": 192,
    "num_layers": 4,
    "num_heads": 4,
    "num_kv_heads": 4,
    "ffn_multiplier": 4.0,
    "activation": "swiglu",
    "attention_impl": "mha",
    "use_moe": false,
    "num_experts": 4,
    "num_shared_experts": 0,
    "top_k": 2,
    "moe_aux_loss_weight": 0.01,
    "dropout": 0.0
  },
  "train": {
    "batch_size": 2,
    "learning_rate": 0.00005,
    "min_lr_ratio": 0.1,
    "warmup_steps": 5,
    "weight_decay": 0.0,
    "grad_clip": 1.0,
    "max_steps": 30,
    "eval_interval": 10,
    "save_interval": 15,
    "dtype": "bfloat16",
    "seed": 42,
    "out_dir": "out"
  },
  "grpo": {
    "group_size": 4,
    "max_new_tokens": 24,
    "temperature": 0.8,
    "top_k": 40,
    "kl_beta": 0.02
  }
}
